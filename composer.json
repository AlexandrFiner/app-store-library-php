{
    "name": "alexandrfiner/app-store-library-php",
    "description": "A library that implements the App Store API (Server API and Connect API) and facilitates App Store Server Notifications V2",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "appstore",
        "connectapi",
        "serverapi",
        "server notifications",
        "iap",
        "itunes"
    ],
    "authors": [
        {
            "name": "Alexandr Morohin",
            "email": "finersanya@gmail.com",
            "homepage": "https://github.com/AlexandrFiner"
        }
    ],
    "homepage": "https://github.com/AlexandrFiner/app-store-library-php",
    "require": {
        "php": "^8.1",
        "firebase/php-jwt": "^6.10",
        "guzzlehttp/psr7": "^2.6",
        "guzzlehttp/uri-template": "^1.0",
        "guzzlehttp/promises": "^2.0",
        "guzzlehttp/guzzle": "^7.8",
        "nesbot/carbon": "^3.8.4",
        "illuminate/collections": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "symfony/intl": "8.1.x-dev"
    },
    "require-dev": {
        "symfony/var-dumper": "7.3.x-dev",
        "friendsofphp/php-cs-fixer": "dev-master"
    },
    "minimum-stability": "dev",
    "autoload": {
        "psr-4": {
            "AppStoreLibrary\\": "src/"
        }
    },
    "scripts": {
        "phpcs": "php-cs-fixer fix -v --diff --dry-run",
        "style-check": [
            "@phpcs"
        ],
        "test": [
            "@style-check"
        ]
    }
}
